{
  "manifest_version": 3,
  "name": "WebVuln Scanner",
  "version": "1.0.0",
  "description": "현재 웹페이지의 취약한 코드를 정적 분석하여 보안 취약점을 탐지합니다.",
  "icons": {
    "16": "icons/icon.svg",
    "48": "icons/icon.svg",
    "128": "icons/icon.svg"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon.svg",
      "48": "icons/icon.svg",
      "128": "icons/icon.svg"
    },
    "default_title": "WebVuln Scanner"
  },
  "background": {
    "service_worker": "background/background.js"
  },
  "content_scripts": [],
  "permissions": [
    "activeTab",
    "scripting",
    "cookies",
    "storage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}
